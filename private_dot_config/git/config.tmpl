[user]
	email = "colden@coldencullen.com"
	name = "Colden Cullen"
	signingkey = "ssh-rsa "

[advice]
	skippedCherryPicks = false

[alias]
	amend = "commit --amend --no-edit"
	diff-upstream = "!git diff $(git rev-parse --abbrev-ref HEAD)..$(git rev-parse --abbrev-ref HEAD@{upstream})"
	log-upstream = "!git log $(git rev-parse --abbrev-ref HEAD)..$(git rev-parse --abbrev-ref HEAD@{upstream})"

[commit]
	gpgsign = true

[gpg]
	format = "ssh"

[credential "https://gist.github.com"]
	helper = "gh auth git-credential"

[credential "https://github.com"]
	helper = "gh auth git-credential"

[filter "lfs"]
	required = true
	clean = "git-lfs clean -- %f"
	process = "git-lfs filter-process"
	smudge = "git-lfs smudge -- %f"

{{ if eq .chezmoi.os "linux" }}
[gpg "ssh"]
	program = "/opt/1Password/op-ssh-sign"
{{ end }}

[difftool]
    guiDefault = true

[mergetool]
    guiDefault = true

[init]
	defaultBranch = "main"

[status]
    showStash = true

[checkout]
	workers = 0

[rebase]
    autoStash = true

[fetch]
	all = true
	prune = true
	parallel = 0

[pull]
	rebase = true

[push]
	autoSetupRemote = true
	gpgSign = "if-asked"

[submodule]
    featchJobs = 0
